        <mxCell id="an1" value="&lt;b&gt;PII Classifier&lt;/b&gt;&lt;br&gt;&lt;i&gt;pii_classifier.py&lt;/i&gt;&lt;br&gt;&lt;hr&gt;- Field-level PII detection&lt;br&gt;- Direct identifier check&lt;br&gt;- Quasi-identifier tagging&lt;br&gt;- Sensitivity levels:&lt;br&gt;  High / Medium / Low" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;fontSize=10;fontColor=#000000;align=left;spacingLeft=8;" parent="1" vertex="1">
